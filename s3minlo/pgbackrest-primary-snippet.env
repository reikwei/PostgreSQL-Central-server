# 把以下变量写入主库 VPS 的 /home/pg-center-kit/.env
#
# 这是一份示例片段。
# 实际值请以备份 VPS 安装完成后生成的 /root/minio-pgbackrest-credentials.txt 为准。

PGBR_REPO_TYPE=s3
PGBR_REPO_PATH=/pgbackrest
PGBR_S3_BUCKET=pgbackrest-prod
PGBR_S3_ENDPOINT=10.66.0.2:9000
PGBR_S3_REGION=us-east-1
PGBR_S3_KEY=pgbackrest
PGBR_S3_KEY_SECRET=替换成备份 VPS 生成的 secret
PGBR_S3_URI_STYLE=path

# 如果主库和备份 VPS 通过 WireGuard 内网通讯，且 MinIO 没有单独配 HTTPS，设成 n。
# 如果你另外给 MinIO 配了 HTTPS，再改成 y。
PGBR_S3_VERIFY_TLS=n