# 备份 VPS 的 MinIO 配置模板
#
# 推荐默认思路:
# 1. 让备份 VPS 也加入 WireGuard。
# 2. MinIO API 只监听备份 VPS 的 WireGuard 地址。
# 3. 防火墙只允许主库 VPS 的 WireGuard 地址访问 9000。
# 4. Console 只监听 127.0.0.1，然后用 SSH 隧道临时管理。

# MinIO 运行账号
MINIO_USER=minio
MINIO_GROUP=minio

# 数据与配置目录
MINIO_DATA_DIR=/var/lib/minio
MINIO_CONFIG_DIR=/etc/minio

# MinIO API 和 Console 监听地址
# 如果备份 VPS 已加入 WireGuard，建议把 10.66.0.2 改成你的备份 VPS 内网地址。
MINIO_API_ADDRESS=10.66.0.2:9000
MINIO_CONSOLE_ADDRESS=127.0.0.1:9001

# 对外给主库访问的 URL
# 如果主库通过 WireGuard 访问，这里就写 WireGuard 地址。
MINIO_SERVER_URL=http://10.66.0.2:9000

# Root 账号。为空时脚本会自动生成强密码并写到 /root/minio-pgbackrest-credentials.txt。
MINIO_ROOT_USER=minio-root
MINIO_ROOT_PASSWORD=

# pgBackRest 使用的 bucket 和前缀
PGBR_BUCKET=pgbackrest-prod
PGBR_PREFIX=/pgbackrest
PGBR_POLICY_NAME=pgbackrest-rw

# 给主库 pgBackRest 用的专用访问密钥。secret 留空时脚本自动生成。
MINIO_PGBR_ACCESS_KEY=pgbackrest
MINIO_PGBR_SECRET_KEY=

# 防火墙
SSH_PORT=22
# 建议改成你自己的办公出口 /32。
ALLOW_SSH_CIDR=0.0.0.0/0
# 这里只允许主库地址访问 MinIO API。
# 如果主库通过 WireGuard 访问，就填主库的 WireGuard IP，例如 10.66.0.1/32。
ALLOW_MINIO_CIDR=10.66.0.1/32
ENABLE_UFW=true