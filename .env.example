# PostgreSQL 中心服务器配置模板
#
# 使用方式:
# 1. 复制本文件为 .env
# 2. 按你的实际机器和组网环境修改下面的值
# 3. 执行 sudo bash install.sh ./.env

# PostgreSQL 主版本与集群名
PG_MAJOR=16
PG_CLUSTER=main
PG_PORT=5432

# 业务数据库名称、用户名和密码
APP_DB_NAME=robot_center
APP_DB_USER=robot_app
APP_DB_PASSWORD=

# PostgreSQL 核心参数
# auto 表示由安装脚本根据机器内存自动计算。
PG_MAX_CONNECTIONS=200
PG_SHARED_BUFFERS=auto
PG_EFFECTIVE_CACHE_SIZE=auto
PG_MAINTENANCE_WORK_MEM=auto
PG_WAL_BUFFERS=16MB
PG_CHECKPOINT_TIMEOUT=15min
PG_MAX_WAL_SIZE=4GB
PG_MIN_WAL_SIZE=1GB

# 高并发写入时常用 off。
# 如果你更重视已确认事务的稳妥性，改成 on。
PG_SYNCHRONOUS_COMMIT=off

# PgBouncer 连接池
# transaction 最省连接；如果应用依赖会话级状态，可改成 session。
PGB_PORT=6432
PGB_POOL_MODE=transaction
PGB_MAX_CLIENT_CONN=5000
PGB_DEFAULT_POOL_SIZE=40
PGB_MIN_POOL_SIZE=10
PGB_RESERVE_POOL_SIZE=10
PGB_MAX_DB_CONNECTIONS=80
PGB_MAX_USER_CONNECTIONS=80

# WireGuard 组网
WG_INTERFACE=wg0
WG_PORT=51820
WG_MTU=1380
WG_SUBNET=10.66.0.0/24
WG_SERVER_IP=10.66.0.1
WG_CLIENT_DNS=1.1.1.1

# 当前主库的公网地址或域名。
# 客户端生成 WireGuard 配置时会用到它。
PUBLIC_ENDPOINT=

# 防火墙与 SSH
SSH_PORT=22

# 建议改成你自己的办公网或家庭宽带出口，例如 1.2.3.4/32。
ALLOW_SSH_CIDR=0.0.0.0/0
ENABLE_UFW=true

# pgBackRest
PGBR_STANZA=pgcenter

# local 表示备份先存本机。
# s3 表示写到 S3 兼容对象存储，例如 AWS S3 或自建 MinIO。
PGBR_REPO_TYPE=local
PGBR_REPO_PATH=/var/lib/pgbackrest
PGBR_PROCESS_MAX=2
PGBR_COMPRESS_TYPE=zst
PGBR_ARCHIVE_ASYNC=y
PGBR_START_FAST=y
PGBR_DELTA=y
PGBR_RETENTION_FULL=2
PGBR_RETENTION_DIFF=6

# 这里是 systemd OnCalendar 表达式。
# 因为值里有空格，所以必须带双引号。
PGBR_FULL_ONCALENDAR="Sun *-*-* 03:20:00"
PGBR_INCR_ONCALENDAR="Mon..Sat *-*-* 03:20:00"

# S3 兼容对象存储参数
# 只有在 PGBR_REPO_TYPE=s3 时才需要填写。
PGBR_S3_BUCKET=
PGBR_S3_ENDPOINT=
PGBR_S3_REGION=
PGBR_S3_KEY=
PGBR_S3_KEY_SECRET=

# 自建 MinIO 常用 path。
PGBR_S3_URI_STYLE=path

# 如果通过 WireGuard 内网访问 MinIO，且未单独配置 HTTPS，可设为 n。
# 如果是 HTTPS 端点，设为 y。
PGBR_S3_VERIFY_TLS=y